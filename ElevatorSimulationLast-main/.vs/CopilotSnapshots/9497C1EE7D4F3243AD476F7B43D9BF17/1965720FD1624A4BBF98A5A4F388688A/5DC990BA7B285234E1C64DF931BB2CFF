<Window x:Class="elevator_simulation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:elevator_simulation"
        xmlns:vm="clr-namespace:elevator_simulation.ViewModels"
        xmlns:conv="clr-namespace:elevator_simulation.Converters"
        mc:Ignorable="d"
        Title="Asansor Simulasyonu" Height="700" Width="1000">

	<Window.Resources>
		<conv:FloorToPositionConverter x:Key="FloorToPositionConverter"/>
		<conv:FloorListPositionConverter x:Key="FloorListPositionConverter"/>
		<conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
		<conv:PassengerStatusConverter x:Key="PassengerStatusConverter"/>
		<conv:FloorEqualityConverter x:Key="FloorEqualityConverter"/>
		<conv:DoorPositionConverter x:Key="DoorPositionConverter"/>
	</Window.Resources>

	<Window.DataContext>
		<vm:MainViewModel />
	</Window.DataContext>

	<Grid Background="#0f0f0f">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="200"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="250"/>
		</Grid.ColumnDefinitions>

		<!-- Sol Panel -->
		<Border Grid.Column="0" Background="White" Margin="1" CornerRadius="5">
			<Border.Effect>
				<DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
			</Border.Effect>
			<DockPanel Margin="10" LastChildFill="True">
				<!-- ACİL DURUM BUTONU -->
				<Button x:Name="btnEmergency" 
						DockPanel.Dock="Top"
						Click="BtnEmergency_Click"
						Height="60" 
						Margin="0,0,0,15" 
						BorderThickness="3"
						Cursor="Hand">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background">
								<Setter.Value>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#D32F2F" Offset="0"/>
										<GradientStop Color="#B71C1C" Offset="1"/>
									</LinearGradientBrush>
								</Setter.Value>
							</Setter>
							<Setter Property="BorderBrush" Value="#C62828"/>
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" 
												BorderBrush="{TemplateBinding BorderBrush}"
												BorderThickness="{TemplateBinding BorderThickness}"
												CornerRadius="10">
											<Border.Effect>
												<DropShadowEffect BlurRadius="15" ShadowDepth="5" 
																Opacity="0.6" Color="#D32F2F"/>
											</Border.Effect>
											<Border.RenderTransform>
												<ScaleTransform x:Name="ButtonScale" 
																ScaleX="1" ScaleY="1" 
																CenterX="90" CenterY="30"/>
											</Border.RenderTransform>
											<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
												<TextBlock Text="🚨 ACİL DURUM" 
														  FontSize="16" FontWeight="Black" 
														  Foreground="White"
														  HorizontalAlignment="Center"
														  Margin="0,0,0,3"/>
												<TextBlock Text="Tüm Asansörleri Durdur" 
														  FontSize="9" 
														  Foreground="#FFCDD2"
														  HorizontalAlignment="Center"/>
											</StackPanel>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Trigger.EnterActions>
													<BeginStoryboard>
														<Storyboard>
															<DoubleAnimation Storyboard.TargetName="ButtonScale"
																			Storyboard.TargetProperty="ScaleX"
																			To="1.05" Duration="0:0:0.2"/>
															<DoubleAnimation Storyboard.TargetName="ButtonScale"
																			Storyboard.TargetProperty="ScaleY"
																			To="1.05" Duration="0:0:0.2"/>
														</Storyboard>
													</BeginStoryboard>
												</Trigger.EnterActions>
												<Trigger.ExitActions>
													<BeginStoryboard>
														<Storyboard>
															<DoubleAnimation Storyboard.TargetName="ButtonScale"
																			Storyboard.TargetProperty="ScaleX"
																			To="1.0" Duration="0:0:0.2"/>
															<DoubleAnimation Storyboard.TargetName="ButtonScale"
																			Storyboard.TargetProperty="ScaleY"
																			To="1.0" Duration="0:0:0.2"/>
														</Storyboard>
													</BeginStoryboard>
												</Trigger.ExitActions>
											</Trigger>
											<Trigger Property="IsPressed" Value="True">
												<Setter Property="Background">
													<Setter.Value>
														<SolidColorBrush Color="#9E0000"/>
													</Setter.Value>
												</Setter>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>

				<TextBlock DockPanel.Dock="Top" Text="ASANSORU CAGIR" FontSize="18" FontWeight="Heavy"
						  HorizontalAlignment="Center" Margin="0,0,0,5"/>
				<TextBlock DockPanel.Dock="Top" Text="(Katlardan Cagirma)" FontSize="11" 
						  HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Gray"/>
				
				<!-- Saatlik Park Bilgisi -->
				<Border DockPanel.Dock="Top" Background="#E3F2FD" CornerRadius="6" Padding="8,6" Margin="0,0,0,8">
					<StackPanel>
						<TextBlock Text="📊 Saatlik Park Konumu"
								   FontSize="10" FontWeight="Bold"
								   Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,4"/>
						<TextBlock Text="{Binding HourlyParkInfo}"
								   FontSize="13" FontWeight="SemiBold"
								   Foreground="#0D47A1"
								   HorizontalAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- ML İÇİN SAAT GİRİŞİ -->
				<Border DockPanel.Dock="Top" Background="#FFF3E0" CornerRadius="5" Padding="10" Margin="0,0,0,6">
					<StackPanel>
						<TextBlock Text="⏰ ML Simülasyon Saati" FontSize="12" FontWeight="Bold" 
								   Foreground="#F57C00" HorizontalAlignment="Center" Margin="0,0,0,5"/>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
							<TextBox x:Name="txtHour" Width="40" Height="30" Text="08" 
									 FontSize="16" TextAlignment="Center" 
									 VerticalContentAlignment="Center" MaxLength="2"/>
							<TextBlock Text=" : " FontSize="20" FontWeight="Bold" 
									   VerticalAlignment="Center" Margin="5,0"/>
							<TextBox x:Name="txtMinute" Width="40" Height="30" Text="00" 
									 FontSize="16" TextAlignment="Center" 
									 VerticalContentAlignment="Center" MaxLength="2"/>
						</StackPanel>
						<Button x:Name="btnToggleClock" Content="⏸ Durdur" Height="26"
								Margin="0,6,0,0" FontSize="11" FontWeight="Bold"
								Background="#F57C00" Foreground="White" BorderThickness="0"
								Cursor="Hand" Click="BtnToggleClock_Click"/>
						<TextBlock x:Name="txtDataCount" Text="Toplanan Veri: 0" 
								   FontSize="10" Foreground="Gray" 
								   HorizontalAlignment="Center" Margin="0,5,0,0"/>
					</StackPanel>
				</Border>

				<!-- PERFORMANS DASHBOARD BUTONU -->
				<Button x:Name="btnPerformanceDashboard"
						DockPanel.Dock="Top"
						Content="📊 Performans Raporu"
						Click="BtnPerformanceDashboard_Click"
						Height="34" Margin="0,0,0,8"
						Cursor="Hand">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background"   Value="#0f3460"/>
							<Setter Property="Foreground"   Value="White"/>
							<Setter Property="FontSize"     Value="12"/>
							<Setter Property="FontWeight"   Value="SemiBold"/>
							<Setter Property="BorderBrush"  Value="#ffb6c1"/>
							<Setter Property="BorderThickness" Value="1"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}"
												BorderBrush="{TemplateBinding BorderBrush}"
												BorderThickness="{TemplateBinding BorderThickness}"
												CornerRadius="7">
											<ContentPresenter HorizontalAlignment="Center"
															  VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Background" Value="#1a4a80"/>
											</Trigger>
											<Trigger Property="IsPressed" Value="True">
												<Setter Property="Background" Value="#0a2040"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>


				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding Floors}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Content="{Binding}" 
                                        Command="{Binding DataContext.CallElevatorCommand, 
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Height="35" Margin="5" FontSize="14" FontWeight="Bold"
                                        BorderThickness="0" Cursor="Hand">
									<Button.Template>
										<ControlTemplate TargetType="Button">
											<Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="5" Padding="5">
												<ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
											</Border>
										</ControlTemplate>
									</Button.Template>
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Background" Value="#Ffc0cb"/>
											<Setter Property="Foreground" Value="Brown"/>
											<Style.Triggers>
												<DataTrigger Value="True">
													<DataTrigger.Binding>
														<MultiBinding Converter="{StaticResource FloorEqualityConverter}">
															<Binding />
															<Binding Path="DataContext.CurrentFloor" 
                                                                    RelativeSource="{RelativeSource AncestorType=Window}"/>
														</MultiBinding>
													</DataTrigger.Binding>
													<Setter Property="Background" Value="#4CAF50"/>
												</DataTrigger>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#fea9b8"/>
												</Trigger>
												<Trigger Property="IsEnabled" Value="False">
													<Setter Property="Background" Value="#CCCCCC"/>
													<Setter Property="Foreground" Value="Brown"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</DockPanel>
		</Border>

		<!-- Orta Panel Asansor -->
		<Border Grid.Column="1" Background="White" Margin="10" CornerRadius="5">
			<Border.Effect>
				<DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
			</Border.Effect>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0" Text="ASANSOR SIMULASYONU (2 Asansör)" 
						  FontSize="24" FontWeight="Bold" 
						  HorizontalAlignment="Center" Margin="0,20,0,20"
						  Foreground="#68228b"/>

				<!-- İki Asansör: Yan Yana -->
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<!-- ASANSÖR 1 -->
					<ScrollViewer x:Name="ScrollViewer1" Grid.Column="0" Margin="10" 
								  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
						<Border Background="#ffb6c1" BorderBrush="Black" BorderThickness="2">
							<Grid ClipToBounds="True">
								<!-- Başlık -->
							<TextBlock Text="ASANSÖR 1" FontSize="14" FontWeight="Bold" 
									   Foreground="#68228b" HorizontalAlignment="Center" 
									   VerticalAlignment="Top" Margin="0,5,0,0" Panel.ZIndex="100"/>

							<!-- Asansor Ray Sistemi (Sol) -->
							<Rectangle Width="4" Fill="#2C2C2C" HorizontalAlignment="Left" Margin="40,0,0,0"/>
							<Rectangle Width="2" Fill="#666666" HorizontalAlignment="Left" Margin="41,0,0,0" Opacity="0.5"/>

							<!-- Asansor Ray Sistemi (Sag) -->
							<Rectangle Width="4" Fill="#2C2C2C" HorizontalAlignment="Right" Margin="0,0,40,0"/>
							<Rectangle Width="2" Fill="#666666" HorizontalAlignment="Right" Margin="0,0,41,0" Opacity="0.5"/>

							<Canvas x:Name="MainCanvas" VerticalAlignment="Bottom" Height="1100" Margin="0,25,0,0">
								<Canvas.RenderTransform>
									<TranslateTransform Y="{Binding CurrentFloor, 
									Converter={StaticResource FloorListPositionConverter}}"/>
								</Canvas.RenderTransform>
							</Canvas>

						<!-- Asansor Kabini Ana Container -->
						<Grid Width="230" Height="80" 
                             VerticalAlignment="Bottom"
                             HorizontalAlignment="Center">
							<Grid.RenderTransform>
								<TranslateTransform Y="{Binding CurrentFloor, 
                                    Converter={StaticResource FloorToPositionConverter}}"/>
							</Grid.RenderTransform>

							<!-- Dis Metal Cerceve -->
							<Border Background="#2C2C2C"
                                   BorderBrush="#1A1A1A" 
                                   BorderThickness="5"
                                   CornerRadius="4">
								<Border.Effect>
									<DropShadowEffect BlurRadius="20" ShadowDepth="10" Opacity="0.7" Color="Black"/>
								</Border.Effect>

								<!-- Ic Yapilar (Tek Child) -->
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="28*"/>
										<ColumnDefinition Width="27*"/>
										<ColumnDefinition Width="165*"/>
									</Grid.ColumnDefinitions>
									<!-- Metal Parlama Efekti (Ust Cerceve) -->
									<Border Height="10" VerticalAlignment="Top" Margin="0" 
                                           CornerRadius="2,2,0,0" Grid.ColumnSpan="3">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
												<GradientStop Color="#888888" Offset="0"/>
												<GradientStop Color="#444444" Offset="0.5"/>
												<GradientStop Color="#2C2C2C" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
									</Border>

									<!-- Metal Parlama Efekti (Sol Kenar) -->
									<Border Width="8" HorizontalAlignment="Left" Margin="0,10,0,10">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
												<GradientStop Color="#666666" Offset="0"/>
												<GradientStop Color="#3C3C3C" Offset="0.5"/>
												<GradientStop Color="#2C2C2C" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
									</Border>

									<!-- Metal Parlama Efekti (Sag Kenar) -->
									<Border Width="8" HorizontalAlignment="Left" Margin="157,10,0,10" Grid.Column="2">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
												<GradientStop Color="#2C2C2C" Offset="0"/>
												<GradientStop Color="#3C3C3C" Offset="0.5"/>
												<GradientStop Color="#555555" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
									</Border>

									<!-- Ic Panel Arka Plan -->
									<Border Margin="5,5,5,5" Background="#cd6889" CornerRadius="2" ClipToBounds="True" Grid.ColumnSpan="3">
										<Grid>
											<!-- Dijital Kat Gosterge Paneli (Ust) -->
											<Border Height="22" VerticalAlignment="Top" 
                                                   Background="#0D0D0D" 
                                                   BorderBrush="#333333" 
                                                   BorderThickness="0,0,0,2">
												<Grid>
													<!-- LED Ekran Efekti -->
													<Rectangle Fill="#1A1A1A" Opacity="0.8"/>
													<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
														<TextBlock Text="FLOOR" FontSize="9" FontWeight="Bold" 
                                                                  Foreground="#FF6B00" 
                                                                  FontFamily="Consolas"
                                                                  Margin="0,0,8,0" Opacity="0.7"/>
														<Border Background="#000000" Padding="10,2" CornerRadius="3"
                                                               BorderBrush="#FF6B00" BorderThickness="1.5">
															<TextBlock Text="{Binding CurrentFloor}" 
                                                                      FontSize="14" FontWeight="Bold" 
                                                                      Foreground="#FF6B00" 
                                                                      FontFamily="Consolas"
                                                                      HorizontalAlignment="Center">
																<TextBlock.Effect>
																	<DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#FF6B00" Opacity="0.8"/>
																</TextBlock.Effect>
															</TextBlock>
														</Border>
													</StackPanel>
												</Grid>
											</Border>

											<!-- Ana Asansor Alani -->
											<Grid Margin="0,22,0,0">
												<!-- Asansor Ici Zemin Efekti -->
												<Rectangle Fill="#ba5a7c" Opacity="0.3" VerticalAlignment="Bottom" Height="8"/>

												<!-- Ana Kat Numarasi Gosterimi -->
												<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
													<TextBlock Text="{Binding CurrentFloor}" 
                                                              FontSize="36" FontWeight="Black" 
                                                              Foreground="#FFEB3B"
                                                              HorizontalAlignment="Center">
														<TextBlock.Effect>
															<DropShadowEffect BlurRadius="6" ShadowDepth="3" Color="Black" Opacity="0.9"/>
														</TextBlock.Effect>
													</TextBlock>
												</StackPanel>

										<!-- Yolcu Gostergesi (LED Tarzı - Dinamik) -->
										<Border Background="#1A1A1A" 
                                                       CornerRadius="15" 
                                                       Padding="8,4"
                                                       HorizontalAlignment="Right" 
                                                       VerticalAlignment="Top"
                                                       Margin="0,5,8,0"
                                                       BorderBrush="#00FF00"
                                                       BorderThickness="1.5"
                                                       Visibility="{Binding HasPassenger, 
                                                           Converter={StaticResource BoolToVisibilityConverter}}">
											<Border.Effect>
												<DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#00FF00" Opacity="0.6"/>
											</Border.Effect>
											<StackPanel Orientation="Horizontal">
												<ItemsControl ItemsSource="{Binding PassengerIcons}">
													<ItemsControl.ItemsPanel>
														<ItemsPanelTemplate>
															<StackPanel Orientation="Horizontal"/>
														</ItemsPanelTemplate>
													</ItemsControl.ItemsPanel>
													<ItemsControl.ItemTemplate>
														<DataTemplate>
															<TextBlock Text="&#x1F464;" FontSize="13" Foreground="#00FF00" Margin="1,0"/>
														</DataTemplate>
													</ItemsControl.ItemTemplate>
												</ItemsControl>
												<TextBlock Text="{Binding PassengerCount}" FontSize="12" FontWeight="Bold" 
                                          Foreground="#00FF00" VerticalAlignment="Center" Margin="4,0,0,0"/>
											</StackPanel>
										</Border>

												<!-- KAPI SiSTEMi -->
												<!-- Sol Kapi -->
												<Border Width="110" Height="60"
                                                       Background="#6b044f"
                                                       HorizontalAlignment="Left"
                                                       Panel.ZIndex="10"
                                                       BorderBrush="#4A0336" BorderThickness="0,0,2,0">
													<Border.RenderTransform>
														<TranslateTransform X="{Binding DoorOpenAmount, 
                                                            Converter={StaticResource DoorPositionConverter}, 
                                                            ConverterParameter=Left}"/>
													</Border.RenderTransform>
													<Grid>
														<!-- Kapi Paneli Dikey Cizgileri -->
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Left" Margin="12,0,0,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Left" Margin="12,0,0,0" Opacity="0.5"/>
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Left" Margin="28,0,0,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Left" Margin="28,0,0,0" Opacity="0.5"/>
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Left" Margin="44,0,0,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Left" Margin="44,0,0,0" Opacity="0.5"/>

														<!-- Kapi Ayrac� (Metal Cerceve) -->
														<Rectangle Width="4" Fill="#3A0226" HorizontalAlignment="Right"/>
														<Rectangle Width="1" Fill="#8B1A5A" HorizontalAlignment="Right" Margin="0,0,1,0"/>

														<!-- Kapi Kolu (Altin Metal) -->
														<Border Width="7" Height="25" 
                                                               CornerRadius="3.5"
                                                               HorizontalAlignment="Right" 
                                                               VerticalAlignment="Center" 
                                                               Margin="0,0,12,0">
															<Border.Background>
																<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
																	<GradientStop Color="#DAA520" Offset="0"/>
																	<GradientStop Color="#FFD700" Offset="0.5"/>
																	<GradientStop Color="#B8860B" Offset="1"/>
																</LinearGradientBrush>
															</Border.Background>
															<Border.Effect>
																<DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.6" Color="Black"/>
															</Border.Effect>
														</Border>
													</Grid>
												</Border>

												<!-- Sag Kapi -->
												<Border Width="110" Height="60"
                                                       Background="#6b044f"
                                                       HorizontalAlignment="Right"
                                                       Panel.ZIndex="10"
                                                       BorderBrush="#4A0336" BorderThickness="2,0,0,0">
													<Border.RenderTransform>
														<TranslateTransform X="{Binding DoorOpenAmount, 
                                                            Converter={StaticResource DoorPositionConverter}, 
                                                            ConverterParameter=Right}"/>
													</Border.RenderTransform>
													<Grid>
														<!-- Kapi Paneli Dikey Cizgileri -->
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Right" Margin="0,0,12,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Right" Margin="0,0,12,0" Opacity="0.5"/>
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Right" Margin="0,0,28,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Right" Margin="0,0,28,0" Opacity="0.5"/>
														<Rectangle Width="3" Fill="#8B1A5A" HorizontalAlignment="Right" Margin="0,0,44,0"/>
														<Rectangle Width="2" Fill="#A52A6A" HorizontalAlignment="Right" Margin="0,0,44,0" Opacity="0.5"/>

														<!-- Kapi Ayrac� (Metal Cerceve) -->
														<Rectangle Width="4" Fill="#3A0226" HorizontalAlignment="Left"/>
														<Rectangle Width="1" Fill="#8B1A5A" HorizontalAlignment="Left" Margin="1,0,0,0"/>

														<!-- Kapi Kolu (Altin Metal) -->
														<Border Width="7" Height="25" 
                                                               CornerRadius="3.5"
                                                               HorizontalAlignment="Left" 
                                                               VerticalAlignment="Center" 
                                                               Margin="12,0,0,0">
															<Border.Background>
																<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
																	<GradientStop Color="#B8860B" Offset="0"/>
																	<GradientStop Color="#FFD700" Offset="0.5"/>
																	<GradientStop Color="#DAA520" Offset="1"/>
																</LinearGradientBrush>
															</Border.Background>
															<Border.Effect>
																<DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.6" Color="Black"/>
															</Border.Effect>
														</Border>
													</Grid>
												</Border>
											</Grid>
										</Grid>
									</Border>

									<!-- Alt Metal Tampon/Koruma -->
									<Border Height="5" VerticalAlignment="Bottom" 
                                           Margin="0" Grid.ColumnSpan="3">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
												<GradientStop Color="#3C3C3C" Offset="0"/>
												<GradientStop Color="#1A1A1A" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
										<Border.Effect>
											<DropShadowEffect BlurRadius="4" ShadowDepth="3" Opacity="0.4"/>
										</Border.Effect>
									</Border>
								</Grid>
							</Border>

							<!-- Metal Cerceve Vidalari/Civatalar (4 Kose) -->
