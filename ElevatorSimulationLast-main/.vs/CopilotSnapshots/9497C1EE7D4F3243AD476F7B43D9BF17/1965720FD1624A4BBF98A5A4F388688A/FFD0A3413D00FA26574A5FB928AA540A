using System.IO;
using System.Text;
using System.Collections.Generic;
using System.Linq;
using elevator_simulation.Models;
using ClosedXML.Excel;

namespace elevator_simulation.Services
{
    /// <summary>
    /// Machine Learning için veri toplama servisi
    /// CSV ve Excel formatında eğitim verisi kaydeder
    /// </summary>
    public class MLDataCollector
    {
        private readonly string _csvFilePath;
        private readonly string _excelFilePath;
        private bool _headerWritten = false;
        private XLWorkbook? _workbook;
        private IXLWorksheet? _worksheet;
        private int _excelRowIndex = 2; // 1. satır header

        public MLDataCollector(string csvFilePath = "ml_training_data.csv", string excelFilePath = "ml_training_data.xlsx")
        {
            _csvFilePath = csvFilePath;
            _excelFilePath = excelFilePath;
            
            // CSV kontrolü
            if (File.Exists(_csvFilePath))
            {
                var firstLine = File.ReadLines(_csvFilePath).FirstOrDefault();
                
                // Eski format header'ı varsa dosyayı sil ve yeniden oluştur
                if (firstLine != null && 
                    (firstLine.Contains("SimulationTime") || firstLine.Contains("Hour,Minute,PickupFloor")))
                {
                    File.Delete(_csvFilePath);
                    WriteCSVHeader();
                }
                else if (firstLine != null && firstLine.Contains("Tarih,Saat"))
                {
                    _headerWritten = true;
                }
                else
                {
                    WriteCSVHeader();
                }
            }
            else
            {
                WriteCSVHeader();
            }
            
            // Excel dosyası oluştur veya aç
            InitializeExcel();
        }

        private void InitializeExcel()
        {
            if (File.Exists(_excelFilePath))
            {
                try
                {
                    _workbook = new XLWorkbook(_excelFilePath);
                    _worksheet = _workbook.Worksheet(1);
                    _excelRowIndex = _worksheet.LastRowUsed()?.RowNumber() + 1 ?? 2;
                }
                catch
                {
                    // Dosya bozuksa yeniden oluştur
                    CreateNewExcelFile();
                }
            }
            else
            {
                CreateNewExcelFile();
            }
        }

        private void CreateNewExcelFile()
        {
            _workbook = new XLWorkbook();
            _worksheet = _workbook.Worksheets.Add("ML Verisi");

            // Header'ları yaz
            _worksheet.Cell(1, 1).Value = "Tarih";
            _worksheet.Cell(1, 2).Value = "Saat";
            _worksheet.Cell(1, 3).Value = "Saat (Tam)";
            _worksheet.Cell(1, 4).Value = "Dakika";
            _worksheet.Cell(1, 5).Value = "Çağrı Kat";
            _worksheet.Cell(1, 6).Value = "Asansör Kat";
            _worksheet.Cell(1, 7).Value = "Hedef Kat";
            _worksheet.Cell(1, 8).Value = "Kat Mesafesi";
            _worksheet.Cell(1, 9).Value = "Seçilen Asansör";
            _worksheet.Cell(1, 10).Value = "Bekleme (Saniye)";
            _worksheet.Cell(1, 11).Value = "Toplam Yolcu";
            _worksheet.Cell(1, 12).Value = "Asansör Durum";

            // Header'ları formatla
            var headerRange = _worksheet.Range("A1:L1");
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = XLColor.LightBlue;
            headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

            _excelRowIndex = 2;
            SaveExcel();
        }

        private void WriteCSVHeader()
        {
            var header = "Tarih,Saat,Saat_Tam,Dakika,Cagri_Kat,Asansor_Kat,Hedef_Kat,Kat_Mesafesi,Secilen_Asansor,Bekleme_Saniye,Toplam_Yolcu,Asansor_Durum";
            File.WriteAllText(_csvFilePath, header + Environment.NewLine, Encoding.UTF8);
            _headerWritten = true;
        }

        /// <summary>
        /// ML veri kaydı oluştur - Hem CSV hem Excel'e yaz
        /// </summary>
        public void RecordRequest(
            TimeSpan simulationTime,
            int pickupFloor,
            int elevatorFloorAtRequest,
            int targetFloor,
            int floorDistance,
            string selectedElevator,
            int waitTimeSeconds,
            int totalPassengers,
            string elevatorState)
        {
            // CSV'ye kaydet
            if (!_headerWritten)
            {
                WriteCSVHeader();
            }

            var date = DateTime.Now.ToString("yyyy-MM-dd");
            var time = simulationTime.ToString(@"hh\:mm\:ss");

            var line = $"{date},{time},{simulationTime.Hours},{simulationTime.Minutes}," +
                       $"{pickupFloor},{elevatorFloorAtRequest},{targetFloor},{floorDistance}," +
                       $"{selectedElevator},{waitTimeSeconds},{totalPassengers},{elevatorState}";

            File.AppendAllText(_csvFilePath, line + Environment.NewLine, Encoding.UTF8);

            // Excel'e kaydet
            if (_worksheet != null)
            {
                _worksheet.Cell(_excelRowIndex, 1).Value = date;
                _worksheet.Cell(_excelRowIndex, 2).Value = time;
                _worksheet.Cell(_excelRowIndex, 3).Value = simulationTime.Hours;
                _worksheet.Cell(_excelRowIndex, 4).Value = simulationTime.Minutes;
                _worksheet.Cell(_excelRowIndex, 5).Value = pickupFloor;
                _worksheet.Cell(_excelRowIndex, 6).Value = elevatorFloorAtRequest;
                _worksheet.Cell(_excelRowIndex, 7).Value = targetFloor;
                _worksheet.Cell(_excelRowIndex, 8).Value = floorDistance;
                _worksheet.Cell(_excelRowIndex, 9).Value = selectedElevator;
                _worksheet.Cell(_excelRowIndex, 10).Value = waitTimeSeconds;
                _worksheet.Cell(_excelRowIndex, 11).Value = totalPassengers;
                _worksheet.Cell(_excelRowIndex, 12).Value = elevatorState;

                // Satırları formatla (zebra striping)
                if (_excelRowIndex % 2 == 0)
                {
                    _worksheet.Range($"A{_excelRowIndex}:L{_excelRowIndex}").Style.Fill.BackgroundColor = XLColor.LightGray;
                }

                _excelRowIndex++;
                SaveExcel();
            }
        }

        private void SaveExcel()
        {
            try
            {
                _workbook?.SaveAs(_excelFilePath);
            }
            catch
            {
                // Dosya açıksa veya hata varsa sessizce geç
            }
        }

        /// <summary>
        /// Tüm veriyi temizle (yeni eğitim için)
        /// </summary>
        public void ClearData()
        {
            // CSV temizle
            if (File.Exists(_csvFilePath))
            {
                File.Delete(_csvFilePath);
            }
            _headerWritten = false;
            WriteCSVHeader();
            
            // Excel temizle
            if (File.Exists(_excelFilePath))
            {
                File.Delete(_excelFilePath);
            }
            CreateNewExcelFile();
        }

        /// <summary>
        /// Toplanan veri sayısını döndür
        /// </summary>
        public int GetRecordCount()
        {
            if (!File.Exists(_csvFilePath))
                return 0;

            var lines = File.ReadAllLines(_csvFilePath);
            return Math.Max(0, lines.Length - 1); // Header hariç
        }
        
        /// <summary>
        /// Toplanan ham veriden her saat icin en yogun kati hesaplar
        /// ve elevator_model (1).csv dosyasini gunceller.
        /// Asansor bir sonraki acilista guncel modele gore park eder.
        /// </summary>
        public void RebuildParkingModel(string outputCsvPath)
        {
            if (!File.Exists(_csvFilePath)) return;

            var allLines = File.ReadAllLines(_csvFilePath, Encoding.UTF8);
            if (allLines.Length < 2) return;

            var hourFloorCounts = new Dictionary<int, Dictionary<int, int>>();

            foreach (var line in allLines.Skip(1))
            {
                var parts = line.Split(',');
                if (parts.Length < 5) continue;
                if (!int.TryParse(parts[2], out int hour)) continue;
                if (!int.TryParse(parts[4], out int floor)) continue;

                if (!hourFloorCounts.ContainsKey(hour))
                    hourFloorCounts[hour] = new Dictionary<int, int>();
                if (!hourFloorCounts[hour].ContainsKey(floor))
                    hourFloorCounts[hour][floor] = 0;
                hourFloorCounts[hour][floor]++;
            }

            if (hourFloorCounts.Count == 0) return;

            var sb = new StringBuilder();
            sb.AppendLine("Hour,Floor,Count");

            for (int h = 0; h < 24; h++)
            {
                if (hourFloorCounts.TryGetValue(h, out var floorCounts))
                {
                    int bestFloor = 0, bestCount = 0;
                    foreach (var kv in floorCounts)
                        if (kv.Value > bestCount) { bestCount = kv.Value; bestFloor = kv.Key; }
                    sb.AppendLine($"{h},{bestFloor},{bestCount}");
                }
                else
                {
                    sb.AppendLine($"{h},0,0");
                }
            }

            File.WriteAllText(outputCsvPath, sb.ToString(), Encoding.UTF8);
        }

        /// <summary>
        /// CSV'den Smart Elevator metriklerini okur ve FCFS baseline simüle eder.
        /// </summary>
        public PerformanceMetrics ComputeMetrics()
        {
            var metrics = new PerformanceMetrics();

            if (!File.Exists(_csvFilePath)) return metrics;

            var lines = File.ReadAllLines(_csvFilePath, Encoding.UTF8);
            if (lines.Length < 2) return metrics;

            // (hour, pickupFloor, elevFloor, targetFloor, floorDist, waitSec)
            var records = new List<(int hour, int pickup, int elevFlr, int target, int dist, int wait)>();

            foreach (var line in lines.Skip(1))
            {
                var p = line.Split(',');
                if (p.Length < 11) continue;
                if (!int.TryParse(p[2],  out int hour))   continue; // Saat_Tam
                if (!int.TryParse(p[4],  out int pickup))  continue; // Çağrı_Kat
                if (!int.TryParse(p[5],  out int elevFlr)) continue; // Asansör_Kat
                if (!int.TryParse(p[6],  out int target))  continue; // Hedef_Kat
                if (!int.TryParse(p[7],  out int dist))    continue; // Kat_Mesafesi
                if (!int.TryParse(p[9],  out int wait))    continue; // Bekleme_Saniye
                records.Add((hour, pickup, elevFlr, target, dist, wait));
            }

            if (records.Count == 0) return metrics;

            metrics.TotalRequests = records.Count;

            // ── SMART ELEVATOR (gerçek simülasyon verisi) ──────────────────
            double smartEnergy  = records.Sum(r => r.dist * 0.05);
            double smartAvgWait = records.Average(r => (double)r.wait);
            double smartAvgJrn  = records.Average(r => r.dist * 1.0 + 3.0);
            var    smartPeakW   = records.Where(r => r.hour >= 8 && r.hour <= 10)
                                         .Select(r => (double)r.wait).ToList();
            double smartPeakWait = smartPeakW.Count > 0 ? smartPeakW.Average() : smartAvgWait;

            metrics.SmartTotalEnergy    = Math.Round(smartEnergy,    2);
            metrics.SmartAvgWaitTime    = Math.Round(smartAvgWait,   2);
            metrics.SmartAvgJourneyTime = Math.Round(smartAvgJrn,    2);
            metrics.SmartPeakWaitTime   = Math.Round(smartPeakWait,  2);

            // ── FCFS BASELINE (ilk-gelen ilk-hizmet simülasyonu) ──────────
            double fcfsEnergy = 0, fcfsTotalWait = 0, fcfsTotalJrn = 0;
            int    fcfsCurFloor = 0;
            var    fcfsPeakWaits = new List<double>();

            foreach (var r in records)
            {
                int toPickup  = Math.Abs(fcfsCurFloor - r.pickup);
                int toTarget  = Math.Abs(r.pickup - r.target);
                double waitSec = toPickup * 1.0 + 3.0;
                double jrnSec  = toTarget * 1.0 + 3.0;

                fcfsEnergy    += (toPickup + toTarget) * 0.07;
                fcfsTotalWait += waitSec;
                fcfsTotalJrn  += jrnSec;
                fcfsCurFloor   = r.target;

                if (r.hour >= 8 && r.hour <= 10)
                    fcfsPeakWaits.Add(waitSec);
            }

            metrics.FcfsTotalEnergy    = Math.Round(fcfsEnergy,                         2);
            metrics.FcfsAvgWaitTime    = Math.Round(fcfsTotalWait / records.Count,      2);
            metrics.FcfsAvgJourneyTime = Math.Round(fcfsTotalJrn  / records.Count,      2);
            metrics.FcfsPeakWaitTime   = Math.Round(fcfsPeakWaits.Count > 0
                                             ? fcfsPeakWaits.Average()
                                             : metrics.FcfsAvgWaitTime,                 2);

            return metrics;
        }

        /// <summary>
        /// Kaynaklari temizle
        /// </summary>
        public void Dispose()
        {
            SaveExcel();
            _workbook?.Dispose();
        }
    }
}

