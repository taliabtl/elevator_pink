<Window x:Class="elevator_simulation.Views.PerformanceDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Dashboard"
        Width="960" Height="680"
        MinWidth="800" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1a1a2e">

    <Window.Resources>
        <Style x:Key="ChartTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#e0e0e0"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="UnitLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SystemLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ANA BAŞLIK ══ -->
        <TextBlock Grid.Row="0"
                   Text="Smart Elevator System vs FCFS Baseline Performance Comparison"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center" Margin="0,0,0,4"/>

        <!-- ══ ALT BAŞLIK ══ -->
        <TextBlock Grid.Row="1"
                   Text="Simulation results based on the same passenger request dataset"
                   Foreground="#aaaaaa" FontSize="11" FontStyle="Italic"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- ══ LEGEND ══ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,12">
            <Rectangle Width="16" Height="16" Fill="#ffb6c1" RadiusX="3" RadiusY="3" Margin="0,0,5,0"/>
            <TextBlock Text="Smart Elevator System" Foreground="#e0e0e0" FontSize="12" Margin="0,0,18,0" VerticalAlignment="Center"/>
            <Rectangle Width="16" Height="16" Fill="#68228b" RadiusX="3" RadiusY="3" Margin="0,0,5,0"/>
            <TextBlock Text="FCFS Baseline System"  Foreground="#e0e0e0" FontSize="12" Margin="0,0,0,0"  VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ══ 2x2 GRAFİK ALANI ══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Grafik 1: Total Energy Consumption ── -->
            <Border Grid.Row="0" Grid.Column="0" Background="#16213e" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="⚡  Total Energy Consumption" Style="{StaticResource ChartTitle}"/>
                    <TextBlock Text="Unit: kWh" Style="{StaticResource UnitLabel}"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Smart Elevator" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbEnergySmart" Grid.Column="1" Height="24"
                                     Foreground="#ffb6c1" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbEnergySmart" Grid.Column="2"
                                   Foreground="#ffb6c1" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FCFS Baseline" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbEnergyFcfs" Grid.Column="1" Height="24"
                                     Foreground="#68228b" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbEnergyFcfs" Grid.Column="2"
                                   Foreground="#ce93d8" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Grafik 2: Average Waiting Time ── -->
            <Border Grid.Row="0" Grid.Column="2" Background="#16213e" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="⏱  Average Waiting Time" Style="{StaticResource ChartTitle}"/>
                    <TextBlock Text="Unit: seconds" Style="{StaticResource UnitLabel}"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Smart Elevator" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbWaitSmart" Grid.Column="1" Height="24"
                                     Foreground="#ffb6c1" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbWaitSmart" Grid.Column="2"
                                   Foreground="#ffb6c1" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FCFS Baseline" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbWaitFcfs" Grid.Column="1" Height="24"
                                     Foreground="#68228b" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbWaitFcfs" Grid.Column="2"
                                   Foreground="#ce93d8" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Grafik 3: Average Journey Time ── -->
            <Border Grid.Row="2" Grid.Column="0" Background="#16213e" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="🚗  Average Journey Time" Style="{StaticResource ChartTitle}"/>
                    <TextBlock Text="Unit: seconds" Style="{StaticResource UnitLabel}"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Smart Elevator" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbJourneySmart" Grid.Column="1" Height="24"
                                     Foreground="#ffb6c1" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbJourneySmart" Grid.Column="2"
                                   Foreground="#ffb6c1" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FCFS Baseline" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbJourneyFcfs" Grid.Column="1" Height="24"
                                     Foreground="#68228b" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbJourneyFcfs" Grid.Column="2"
                                   Foreground="#ce93d8" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Grafik 4: Peak-Hour Waiting Time ── -->
            <Border Grid.Row="2" Grid.Column="2" Background="#16213e" CornerRadius="10" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="🔥  Peak-Hour Waiting Time (08:00–10:00)" Style="{StaticResource ChartTitle}"/>
                    <TextBlock Text="Unit: seconds" Style="{StaticResource UnitLabel}"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Smart Elevator" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbPeakSmart" Grid.Column="1" Height="24"
                                     Foreground="#ffb6c1" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbPeakSmart" Grid.Column="2"
                                   Foreground="#ffb6c1" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FCFS Baseline" Style="{StaticResource SystemLabel}"/>
                        <ProgressBar x:Name="pbPeakFcfs" Grid.Column="1" Height="24"
                                     Foreground="#68228b" Background="#2a2a4a" BorderThickness="0"
                                     Maximum="1" Value="0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbPeakFcfs" Grid.Column="2"
                                   Foreground="#ce93d8" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ FOOTER ÖZET ══ -->
        <Border Grid.Row="4" Background="#0f3460" CornerRadius="8" Padding="12,8" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="📊  Summary of Improvements — Smart Elevator vs FCFS Baseline"
                           Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,6"/>
                <WrapPanel Grid.Row="1">
                    <TextBlock x:Name="tbFooterEnergy"  Foreground="#ffb6c1" FontSize="11" Margin="0,0,22,0"/>
                    <TextBlock x:Name="tbFooterWait"    Foreground="#ffb6c1" FontSize="11" Margin="0,0,22,0"/>
                    <TextBlock x:Name="tbFooterJourney" Foreground="#ffb6c1" FontSize="11" Margin="0,0,22,0"/>
                    <TextBlock x:Name="tbFooterPeak"    Foreground="#ffb6c1" FontSize="11" Margin="0,0,22,0"/>
                    <TextBlock x:Name="tbFooterTotal"   Foreground="#aaaaaa" FontSize="11"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
